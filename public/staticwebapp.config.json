{
  "routes": [
    { "route": "/desarrollo-software", "redirect": "/servicios", "statusCode": 301 },
    { "route": "/insights", "redirect": "/", "statusCode": 301 },
    { "route": "/insights/*", "redirect": "/", "statusCode": 301 }
  ],
  "responseOverrides": {
    "404": { "rewrite": "/404.html" }
  },
  "navigationFallback": {
    "rewrite": "/404.html",
    "exclude": ["/assets/*", "*.css", "*.js", "*.png", "*.jpg", "*.svg", "*.ico", "*.webp"]
  }
}
