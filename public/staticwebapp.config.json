{
  "routes": [
    { "route": "/desarrollo-software", "redirect": "/servicios", "statusCode": 301 },
    { "route": "/insights", "redirect": "/", "statusCode": 301 },
    { "route": "/insights/*", "redirect": "/", "statusCode": 301 }
  ],
  "responseOverrides": {
    "404": { "rewrite": "/404.html" }
  },
  "navigationFallback": {
    "rewrite": "/404.html",
    "exclude": ["/api/*", "/assets/*", "*.css", "*.js", "*.png", "*.jpg", "*.svg", "*.ico", "*.webp"]
  },
  "globalHeaders": {
    "Cache-Control": "public, max-age=3600, must-revalidate"
  },
  "platform": {
    "apiRuntime": "node:20"
  }
}
