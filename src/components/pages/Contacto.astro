---
import { t, getLangFromUrl } from '../../i18n/ui';
const lang = getLangFromUrl(Astro.url);
---
<section class="phead"><div class="wrap">
  <div class="eyebrow2">{t('contact.head.eyebrow', lang)}</div>
  <h1>{t('contact.head.title', lang)}</h1>
  <p class="lead">{t('contact.head.lead', lang)}</p>
</div></section>
<section class="sec"><div class="wrap contact-grid">
  <div class="cinfo">
    <div class="row"><div class="ci">✉</div><div><div class="lbl">{t('contact.label.email', lang)}</div><div class="val">info@quantixanalitic.com</div></div></div>
    <div class="row"><div class="ci">✆</div><div><div class="lbl">{t('contact.label.phone', lang)}</div><div class="val">+57 316 474 9204</div></div></div>
    <div class="row"><div class="ci">⌖</div><div><div class="lbl">{t('contact.label.address', lang)}</div><div class="val">Cra. 10b #134a-35, Bogotá D.C.</div></div></div>
    <div class="row"><div class="ci">◷</div><div><div class="lbl">{t('contact.label.site', lang)}</div><div class="val">quantixanalitic.com</div></div></div>
  </div>
  <form
    class="form"
    id="contact-form"
    novalidate
    data-i18n-required={t('contact.form.required', lang)}
    data-i18n-sending={t('contact.form.sending', lang)}
    data-i18n-ok={t('contact.form.ok', lang)}
    data-i18n-err={t('contact.form.err', lang)}
    data-i18n-neterr={t('contact.form.neterr', lang)}
  >
    <label for="cf-name">{t('contact.form.name', lang)}</label>
    <input id="cf-name" name="name" type="text" required maxlength="120" placeholder={t('contact.form.name.ph', lang)} />

    <label for="cf-email">{t('contact.form.email', lang)}</label>
    <input id="cf-email" name="email" type="email" required maxlength="200" placeholder={t('contact.form.email.ph', lang)} />

    <label for="cf-message">{t('contact.form.msg', lang)}</label>
    <textarea id="cf-message" name="message" rows="4" required maxlength="5000" placeholder={t('contact.form.msg.ph', lang)}></textarea>

    <!-- Honeypot anti-spam: invisible para personas; si se llena, se descarta el envío. -->
    <div class="hp" aria-hidden="true">
      <label for="cf-company">No completar este campo</label>
      <input id="cf-company" name="company" type="text" tabindex="-1" autocomplete="off" />
    </div>

    <button class="btn btn-primary" type="submit" id="cf-submit">{t('contact.form.send', lang)}</button>
    <p id="cf-status" class="cf-status" role="status" aria-live="polite"></p>
  </form>
</div></section>

<style>
  .hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }
  .cf-status {
    margin: 12px 0 0;
    font-size: 14px;
    font-weight: 600;
    min-height: 20px;
  }
  .cf-status.ok { color: var(--forest); }
  .cf-status.err { color: #b3261e; }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const status = document.getElementById('cf-status');
  const submit = document.getElementById('cf-submit') as HTMLButtonElement | null;

  if (form && status && submit) {
    const defaultLabel = submit.textContent;
    const msg = {
      required: form.dataset.i18nRequired ?? 'Please complete name, email and message.',
      sending: form.dataset.i18nSending ?? 'Sending…',
      ok: form.dataset.i18nOk ?? 'Message sent ✓',
      err: form.dataset.i18nErr ?? 'Could not send. Please try again.',
      neterr: form.dataset.i18nNeterr ?? 'Could not connect. Please try again.',
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const data = {
        name: (form.elements.namedItem('name') as HTMLInputElement)?.value.trim() ?? '',
        email: (form.elements.namedItem('email') as HTMLInputElement)?.value.trim() ?? '',
        message: (form.elements.namedItem('message') as HTMLTextAreaElement)?.value.trim() ?? '',
        company: (form.elements.namedItem('company') as HTMLInputElement)?.value ?? '',
      };

      // Validación mínima en cliente (el servidor revalida).
      if (!data.name || !data.email || !data.message) {
        status.className = 'cf-status err';
        status.textContent = msg.required;
        return;
      }

      submit.disabled = true;
      submit.textContent = msg.sending;
      status.className = 'cf-status';
      status.textContent = '';

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        const body = await res.json().catch(() => ({}));

        if (res.ok && body.ok) {
          status.className = 'cf-status ok';
          status.textContent = msg.ok;
          form.reset();
        } else {
          status.className = 'cf-status err';
          status.textContent = body.error || msg.err;
        }
      } catch (_) {
        status.className = 'cf-status err';
        status.textContent = msg.neterr;
      } finally {
        submit.disabled = false;
        submit.textContent = defaultLabel;
      }
    });
  }
</script>
