---
import { t, getLangFromUrl, localizedPath } from '../../i18n/ui';
const lang = getLangFromUrl(Astro.url);
---
<section class="hero"><div class="wrap hero-grid">
  <div>
    <span class="eyebrow"><span class="dot"></span>{t('home.hero.eyebrow', lang)}</span>
    <h1>{t('home.hero.title_a', lang)}<span class="g">{t('home.hero.title_hl', lang)}</span>.</h1>
    <p class="sub">{t('home.hero.sub', lang)}</p>
    <div class="cta-row">
      <a class="btn btn-primary" href={localizedPath('viewq', lang)}>{t('home.hero.cta1', lang)}</a>
      <a class="btn btn-ghost" href="#contacto">{t('common.cta.contactUs', lang)}</a>
    </div>
    <div class="trust">
      <span><i>✓</i> {t('home.hero.trust1', lang)}</span>
      <span><i>✓</i> {t('home.hero.trust2', lang)}</span>
      <span><i>✓</i> {t('home.hero.trust3', lang)}</span>
    </div>
  </div>
  <div class="shot">
    <span class="tag">viewQ</span>
    <img src="/assets/viewq-dashboard.png" alt="viewQ" />
  </div>
</div></section>

<section class="vqband"><div class="wrap vq-grid">
  <div class="vqshot"><img src="/assets/qpasa-phone.png" alt="Qpasa" /></div>
  <div>
    <div class="eyebrow2">{t('home.vq.eyebrow', lang)}</div>
    <h2>{t('home.vq.title', lang)}</h2>
    <ul class="vqlist">
      <li><i>›</i> <b>{t('home.vq.li1_b', lang)}</b> {t('home.vq.li1', lang)}</li>
      <li><i>›</i> <b>{t('home.vq.li2_b', lang)}</b> {t('home.vq.li2', lang)}</li>
      <li><i>›</i> <b>{t('home.vq.li3_b', lang)}</b> {t('home.vq.li3', lang)}</li>
    </ul>
    <a class="btn btn-light" href={localizedPath('viewq', lang)}>{t('home.vq.cta', lang)}</a>
  </div>
</div></section>

<section class="sec" id="productos"><div class="wrap">
  <div class="sec-head">
    <div class="eyebrow2">{t('home.prod.eyebrow', lang)}</div>
    <h2>{t('home.prod.title', lang)}</h2>
    <p>{t('home.prod.sub', lang)}</p>
  </div>
  <a href={localizedPath('viewq', lang)} class="prodfeat">
    <div class="pf-ic">Q</div>
    <div class="pf-body">
      <div class="ktag">{t('home.prod.vq.tag', lang)}</div>
      <h3>viewQ</h3>
      <p>{t('home.prod.vq.desc', lang)}</p>
    </div>
    <div class="pf-cta">{t('home.prod.vq.cta', lang)}</div>
  </a>
  <div class="prod-grid3">
    <div class="card flowc">
      <div class="pico flow">F</div>
      <div class="ktag" style="color:var(--teal-d)">{t('home.prod.flow.tag', lang)}</div>
      <h3>Quantix Flow</h3>
      <p>{t('home.prod.flow.desc', lang)}</p>
      <a class="more" href={localizedPath('quantix-flow', lang)}>{t('common.cta.knowMore', lang)}</a>
    </div>
    <div class="card jurc">
      <div class="pico jur">J</div>
      <div class="ktag" style="color:var(--navy2)">{t('home.prod.jur.tag', lang)}</div>
      <h3>QJurídico</h3>
      <p>{t('home.prod.jur.desc', lang)}</p>
      <a class="more" href={localizedPath('qjuridico', lang)}>{t('common.cta.knowMore', lang)}</a>
    </div>
    <div class="card clic">
      <div class="pico cli">✚</div>
      <div class="ktag" style="color:#12517f">{t('home.prod.cli.tag', lang)}</div>
      <h3>Qlinic</h3>
      <p>{t('home.prod.cli.desc', lang)}</p>
      <a class="more" href={localizedPath('qlinic', lang)}>{t('common.cta.knowMore', lang)}</a>
    </div>
  </div>
</div></section>

<section class="aft"><div class="wrap">
  <div class="eyebrow2">{t('home.aft.eyebrow', lang)}</div>
  <h2>{t('home.aft.title', lang)}</h2>
  <p class="lead">{t('home.aft.lead', lang)}</p>
  <div class="pillars">
    <div class="pillar"><h4>{t('home.aft.p1.t', lang)}</h4><p>{t('home.aft.p1.d', lang)}</p></div>
    <div class="pillar"><h4>{t('home.aft.p2.t', lang)}</h4><p>{t('home.aft.p2.d', lang)}</p></div>
    <div class="pillar"><h4>{t('home.aft.p3.t', lang)}</h4><p>{t('home.aft.p3.d', lang)}</p></div>
  </div>
  <div class="eco">{t('home.aft.eco', lang)}</div>
</div></section>

<section class="sec" id="nosotros"><div class="wrap about-grid about">
  <div>
    <h2>{t('home.about.title', lang)}</h2>
    <p>{t('home.about.p1', lang)}</p>
    <p>{t('home.about.p2', lang)}</p>
  </div>
  <div class="founder">
    <div class="av">JR</div>
    <div>
      <div class="nm">Jose Fernando Ramírez Gómez</div>
      <div class="rl">{t('home.about.founder.role', lang)}</div>
    </div>
  </div>
</div></section>

<section class="ctaband" id="contacto"><div class="wrap">
  <h2>{t('contact.head.title', lang)}</h2>
  <p>{t('contact.head.lead', lang)}</p>
  <a class="btn btn-light" href={localizedPath('contacto', lang)}>{t('common.cta.contactUs', lang)}</a>
</div></section>

<style>
  /* hero */
  .hero{background:linear-gradient(180deg,var(--cream) 0%,#fff 100%);padding:62px 0 56px;overflow:hidden}
  .hero-grid{display:grid;grid-template-columns:1.05fr .95fr;gap:44px;align-items:center}
  @media(max-width:920px){.hero-grid{grid-template-columns:1fr;gap:30px}}
  .eyebrow{display:inline-flex;align-items:center;gap:8px;background:var(--mint);color:var(--forest);border:1px solid #cfe3d6;border-radius:30px;padding:6px 14px;font-size:12.5px;font-weight:700;letter-spacing:.4px}
  .eyebrow .dot{width:7px;height:7px;border-radius:50%;background:var(--emerald)}
  .hero h1{font-size:44px;line-height:1.1;margin:18px 0 16px;color:var(--navy);letter-spacing:-.5px}
  .hero h1 .g{color:var(--forest)}
  .hero p.sub{font-size:18px;color:var(--mute);max-width:540px;margin:0 0 26px}
  .hero p.sub b{color:var(--ink)}
  .cta-row{display:flex;gap:12px;flex-wrap:wrap}
  .shot{position:relative}
  .shot img{width:100%;border-radius:14px;box-shadow:0 24px 50px rgba(22,38,63,.18);border:1px solid var(--line)}
  .shot .tag{position:absolute;top:-12px;left:18px;background:var(--forest);color:#fff;font-weight:800;font-size:13px;padding:7px 14px;border-radius:20px;box-shadow:0 8px 18px rgba(15,77,53,.35)}
  .trust{display:flex;gap:26px;flex-wrap:wrap;margin-top:30px;color:var(--mute);font-size:13.5px;font-weight:600}
  .trust span{display:flex;align-items:center;gap:7px} .trust i{color:var(--emerald);font-style:normal;font-weight:900}

  /* viewQ band */
  .vqband{background:var(--forest);color:#fff;padding:56px 0}
  .vq-grid{display:grid;grid-template-columns:.9fr 1.1fr;gap:40px;align-items:center}
  @media(max-width:920px){.vq-grid{grid-template-columns:1fr}}
  .vqband .eyebrow2{font-size:12.5px;font-weight:800;letter-spacing:3px;color:#8fd3a8;text-transform:uppercase}
  .vqband h2{font-size:32px;margin:10px 0 14px;line-height:1.16}
  .vqband p{color:#d7e7de;font-size:16px;max-width:520px;margin:0 0 20px}
  .vqlist{list-style:none;padding:0;margin:0 0 26px}
  .vqlist li{display:flex;gap:11px;align-items:flex-start;margin-bottom:11px;font-size:15px;color:#eaf4ee}
  .vqlist i{color:#8fd3a8;font-style:normal;font-weight:900;margin-top:1px}
  .vqshot img{width:62%;display:block;margin:0 auto;filter:drop-shadow(0 20px 34px rgba(0,0,0,.42))}

  /* products */
  .sec{padding:60px 0}
  .sec-head{text-align:center;max-width:680px;margin:0 auto 38px}
  .sec-head .eyebrow2{font-size:12.5px;font-weight:800;letter-spacing:3px;color:var(--teal-d);text-transform:uppercase}
  .sec-head h2{font-size:31px;color:var(--navy);margin:8px 0 10px}
  .sec-head p{color:var(--mute);font-size:16px;margin:0}
  .prod-grid{display:grid;grid-template-columns:1.6fr 1fr 1fr;gap:18px}
  @media(max-width:920px){.prod-grid{grid-template-columns:1fr}}
  .prodfeat{display:flex;align-items:center;gap:22px;background:linear-gradient(180deg,#f4faf6,#fff);border:1px solid #cfe3d6;border-radius:16px;padding:24px 28px;margin-bottom:18px;transition:.18s}
  .prodfeat:hover{box-shadow:0 16px 34px rgba(22,38,63,.10);transform:translateY(-2px)}
  .prodfeat .pf-ic{width:60px;height:60px;border-radius:14px;background:var(--emerald);color:#fff;display:flex;align-items:center;justify-content:center;font-size:28px;font-weight:900;flex:none}
  .prodfeat .pf-body{flex:1} .prodfeat h3{font-size:24px;color:var(--navy);margin:4px 0 6px}
  .prodfeat .ktag{font-size:11.5px;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;color:var(--emerald)}
  .prodfeat p{color:var(--mute);font-size:14.5px;margin:0;max-width:640px}
  .prodfeat .pf-cta{color:var(--forest);font-weight:800;font-size:15px;white-space:nowrap}
  .prod-grid3{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}
  @media(max-width:860px){.prodfeat{flex-direction:column;align-items:flex-start}.prod-grid3{grid-template-columns:1fr}}
  .card.clic .pico.cli{background:#1C6FB5}
  .card{background:#fff;border:1px solid var(--line);border-radius:16px;padding:26px;transition:.18s}
  .card:hover{box-shadow:0 16px 34px rgba(22,38,63,.10);transform:translateY(-3px)}
  .card.feat{background:linear-gradient(180deg,#f4faf6,#fff);border-color:#cfe3d6}
  .card .pico{width:46px;height:46px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:22px;font-weight:900;color:#fff;margin-bottom:14px}
  .card.feat .pico{background:var(--emerald)} .card .pico.flow{background:var(--teal)} .card .pico.jur{background:var(--navy2)}
  .card .ktag{font-size:11.5px;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;color:var(--emerald)}
  .card h3{font-size:21px;color:var(--navy);margin:7px 0 8px}
  .card p{color:var(--mute);font-size:14.5px;margin:0 0 16px}
  .card a.more{font-weight:700;font-size:14px;color:var(--forest)} .card.flowc a.more{color:var(--teal-d)} .card.jurc a.more{color:var(--navy2)}
  .card.feat h3{font-size:24px}

  /* agrifoodtech strip */
  .aft{background:var(--navy);color:#fff;padding:54px 0}
  .aft .eyebrow2{font-size:12.5px;font-weight:800;letter-spacing:3px;color:#7fe0cf;text-transform:uppercase}
  .aft h2{font-size:28px;margin:10px 0 8px;max-width:620px}
  .aft .lead{color:#c4d4e0;max-width:680px;margin:0 0 28px;font-size:16px}
  .pillars{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
  @media(max-width:760px){.pillars{grid-template-columns:1fr}}
  .pillar{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.13);border-radius:12px;padding:18px}
  .pillar h4{margin:0 0 5px;font-size:15.5px} .pillar p{margin:0;color:#aebfcd;font-size:13px}
  .aft .eco{margin-top:22px;color:#7fe0cf;font-weight:600;font-size:13.5px}

  /* nosotros */
  .about-grid{display:grid;grid-template-columns:1fr 1fr;gap:34px;align-items:center}
  @media(max-width:860px){.about-grid{grid-template-columns:1fr}}
  .about h2{font-size:28px;color:var(--navy);margin:0 0 12px}
  .about p{color:var(--mute);font-size:16px;margin:0 0 12px}
  .founder{background:var(--cream);border:1px solid var(--line);border-radius:16px;padding:24px;display:flex;gap:16px;align-items:center}
  .founder .av{width:62px;height:62px;border-radius:50%;background:var(--forest);color:#fff;display:flex;align-items:center;justify-content:center;font-size:22px;font-weight:800;flex:none}
  .founder .nm{font-weight:800;color:var(--navy);font-size:16.5px}
  .founder .rl{color:var(--teal-d);font-weight:600;font-size:13px;margin:2px 0 6px}
  .founder .ds{color:var(--mute);font-size:13px}

  /* cta band */
  .ctaband{background:var(--emerald);color:#fff;padding:46px 0;text-align:center}
  .ctaband h2{font-size:28px;margin:0 0 8px} .ctaband p{margin:0 0 22px;color:#eafff4;font-size:16px}
</style>
