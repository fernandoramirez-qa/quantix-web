---
import { t, getLangFromUrl, localizedPath } from '../../i18n/ui';
const lang = getLangFromUrl(Astro.url);
---
<section class="phead"><div class="wrap">
  <div class="eyebrow2">{t('flow.head.eyebrow', lang)}</div>
  <h1>{t('flow.head.title', lang)}</h1>
  <p class="lead">{t('flow.head.lead', lang)}</p>
</div></section>
<section class="sec"><div class="wrap"><div class="grid3">
  <div class="card"><div class="ic" style="background:var(--teal)">▤</div><h3>{t('flow.c1.t', lang)}</h3><p>{t('flow.c1.d', lang)}</p></div>
  <div class="card"><div class="ic" style="background:var(--teal)">↻</div><h3>{t('flow.c2.t', lang)}</h3><p>{t('flow.c2.d', lang)}</p></div>
  <div class="card"><div class="ic" style="background:var(--teal)">≈</div><h3>{t('flow.c3.t', lang)}</h3><p>{t('flow.c3.d', lang)}</p></div>
</div></div></section>
<section class="ctaband"><div class="wrap"><h2>{t('flow.cta.title', lang)}</h2>
  <p>{t('flow.cta.sub', lang)}</p><a class="btn btn-light" href={localizedPath('contacto', lang)}>{t('common.cta.requestDemo', lang)}</a></div></section>
