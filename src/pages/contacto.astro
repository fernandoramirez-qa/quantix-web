---
import Base from '../layouts/Base.astro';
---
<Base
  title="Contacto · Quantix Analytic"
  description="Hablemos de su operación. Cuéntenos su reto y le mostramos cómo podemos ayudar — con viewQ o con una solución a la medida."
>
  <section class="phead"><div class="wrap">
    <div class="eyebrow2">Contacto</div>
    <h1>Hablemos de su operación</h1>
    <p class="lead">Cuéntenos su reto y le mostramos cómo podemos ayudar — con viewQ o con una solución a la medida.</p>
  </div></section>
  <section class="sec"><div class="wrap contact-grid">
    <div class="cinfo">
      <div class="row"><div class="ci">✉</div><div><div class="lbl">Correo</div><div class="val">info@quantixanalitic.com</div></div></div>
      <div class="row"><div class="ci">✆</div><div><div class="lbl">WhatsApp / Teléfono</div><div class="val">+57 316 474 9204</div></div></div>
      <div class="row"><div class="ci">⌖</div><div><div class="lbl">Dirección</div><div class="val">Cra. 10b #134a-35, Bogotá D.C.</div></div></div>
      <div class="row"><div class="ci">◷</div><div><div class="lbl">Sitio</div><div class="val">quantixanalitic.com</div></div></div>
    </div>
    <form class="form" onsubmit="return false">
      <label>Nombre</label><input type="text" placeholder="Su nombre">
      <label>Correo o WhatsApp</label><input type="text" placeholder="¿Cómo lo contactamos?">
      <label>¿En qué podemos ayudar?</label><textarea rows="4" placeholder="Cuéntenos brevemente su reto"></textarea>
      <button class="btn btn-primary" type="submit">Enviar mensaje</button>
    </form>
  </div></section>
</Base>
