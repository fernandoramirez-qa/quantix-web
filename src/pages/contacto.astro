---
import Base from '../layouts/Base.astro';
---
<Base
  title="Contacto · Quantix Analitic"
  description="Hablemos de su operación. Cuéntenos su reto y le mostramos cómo podemos ayudar — con viewQ o con una solución a la medida."
>
  <section class="phead"><div class="wrap">
    <div class="eyebrow2">Contacto</div>
    <h1>Hablemos de su operación</h1>
    <p class="lead">Cuéntenos su reto y le mostramos cómo podemos ayudar — con viewQ o con una solución a la medida.</p>
  </div></section>
  <section class="sec"><div class="wrap contact-grid">
    <div class="cinfo">
      <div class="row"><div class="ci">✉</div><div><div class="lbl">Correo</div><div class="val">info@quantixanalitic.com</div></div></div>
      <div class="row"><div class="ci">✆</div><div><div class="lbl">WhatsApp / Teléfono</div><div class="val">+57 316 474 9204</div></div></div>
      <div class="row"><div class="ci">⌖</div><div><div class="lbl">Dirección</div><div class="val">Cra. 10b #134a-35, Bogotá D.C.</div></div></div>
      <div class="row"><div class="ci">◷</div><div><div class="lbl">Sitio</div><div class="val">quantixanalitic.com</div></div></div>
    </div>
    <form class="form" id="contact-form" novalidate>
      <label for="cf-name">Nombre</label>
      <input id="cf-name" name="name" type="text" required maxlength="120" placeholder="Su nombre">

      <label for="cf-email">Correo electrónico</label>
      <input id="cf-email" name="email" type="email" required maxlength="200" placeholder="nombre@empresa.com">

      <label for="cf-message">¿En qué podemos ayudar?</label>
      <textarea id="cf-message" name="message" rows="4" required maxlength="5000" placeholder="Cuéntenos brevemente su reto"></textarea>

      <!-- Honeypot anti-spam: invisible para personas; si se llena, se descarta el envío. -->
      <div class="hp" aria-hidden="true">
        <label for="cf-company">No completar este campo</label>
        <input id="cf-company" name="company" type="text" tabindex="-1" autocomplete="off">
      </div>

      <button class="btn btn-primary" type="submit" id="cf-submit">Enviar mensaje</button>
      <p id="cf-status" class="cf-status" role="status" aria-live="polite"></p>
    </form>
  </div></section>
</Base>

<style>
  .hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }
  .cf-status {
    margin: 12px 0 0;
    font-size: 14px;
    font-weight: 600;
    min-height: 20px;
  }
  .cf-status.ok { color: var(--forest); }
  .cf-status.err { color: #b3261e; }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const status = document.getElementById('cf-status');
  const submit = document.getElementById('cf-submit') as HTMLButtonElement | null;

  if (form && status && submit) {
    const defaultLabel = submit.textContent;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const data = {
        name: (form.elements.namedItem('name') as HTMLInputElement)?.value.trim() ?? '',
        email: (form.elements.namedItem('email') as HTMLInputElement)?.value.trim() ?? '',
        message: (form.elements.namedItem('message') as HTMLTextAreaElement)?.value.trim() ?? '',
        company: (form.elements.namedItem('company') as HTMLInputElement)?.value ?? '',
      };

      // Validación mínima en cliente (el servidor revalida).
      if (!data.name || !data.email || !data.message) {
        status.className = 'cf-status err';
        status.textContent = 'Por favor complete nombre, correo y mensaje.';
        return;
      }

      submit.disabled = true;
      submit.textContent = 'Enviando…';
      status.className = 'cf-status';
      status.textContent = '';

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        const body = await res.json().catch(() => ({}));

        if (res.ok && body.ok) {
          status.className = 'cf-status ok';
          status.textContent = 'Mensaje enviado ✓';
          form.reset();
        } else {
          status.className = 'cf-status err';
          status.textContent = body.error || 'No se pudo enviar el mensaje. Intente de nuevo.';
        }
      } catch (_) {
        status.className = 'cf-status err';
        status.textContent = 'No se pudo conectar. Revise su conexión e intente de nuevo.';
      } finally {
        submit.disabled = false;
        submit.textContent = defaultLabel;
      }
    });
  }
</script>
