---
import Base from '../layouts/Base.astro';
// El 404 es estático y único: Azure SWA lo sirve para cualquier ruta inexistente
// (con o sin prefijo /es/), así que es bilingüe — EN y ES en la misma página.
---
<Base titleText="Page not found · Página no encontrada · Quantix Analitic" is404={true}>
  <section class="phead"><div class="wrap" style="text-align:center">
    <div class="eyebrow2">Error 404</div>
    <h1 style="margin-left:auto;margin-right:auto">This page doesn’t exist · Esta página no existe</h1>
    <p class="lead" style="margin-left:auto;margin-right:auto">
      The address you requested has moved or is unavailable.<br />
      La dirección que buscó cambió o no está disponible.
    </p>
  </div></section>
  <section class="sec" style="padding-top:0"><div class="wrap" style="text-align:center;display:flex;gap:12px;justify-content:center;flex-wrap:wrap">
    <a class="btn btn-primary" href="/">Back to home →</a>
    <a class="btn btn-ghost" href="/es/">Volver al inicio →</a>
  </div></section>
</Base>
