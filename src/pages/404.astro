---
import Base from '../layouts/Base.astro';
---
<Base
  title="Página no encontrada · Quantix Analitic"
  description="La página que busca no existe o cambió de dirección."
>
  <section class="phead"><div class="wrap" style="text-align:center">
    <div class="eyebrow2">Error 404</div>
    <h1 style="margin-left:auto;margin-right:auto">Esta página no existe</h1>
    <p class="lead" style="margin-left:auto;margin-right:auto">La dirección que buscó cambió o no está disponible. Volvamos a un lugar seguro.</p>
  </div></section>
  <section class="sec" style="padding-top:0"><div class="wrap" style="text-align:center">
    <a class="btn btn-primary" href="/">Volver al inicio →</a>
  </div></section>
</Base>
